GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://postgres:postgres@localhost:5432/helpdesk_db
GOOSE_MIGRATION_DIR=./migrations

APP_NAME="Helpdesk App"
APP_HOST=localhost
APP_PORT=8080
CORS_ORIGINS=http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
